@{
    ViewData["Title"] = "Contacts";
}

<div class="container py-5">

    <div class="row g-4">

        <!-- CONTACT INFO -->
        <div class="col-md-5">

            <div class="card product-card p-4 h-100">

                <h2 class="text-primary mb-4">Контакти</h2>

                <p>
                    <strong>Магазин:</strong><br />
                    FightGearShopApp
                </p>

                <p>
                    <strong>Адрес:</strong><br />
                    гр. София, България
                </p>

                <p>
                    <strong>Телефон:</strong><br />
                    +359 888 123 456
                </p>

                <p>
                    <strong>Email:</strong><br />
                    contact@fightgearshop.com
                </p>

                <hr />

                <p class="text-muted">
                    Работно време:<br />
                    Понеделник – Петък: 09:00 – 18:00<br />
                    Събота: 10:00 – 16:00
                </p>

            </div>

        </div>

        <!-- CONTACT FORM -->
        <div class="col-md-7">

            <div class="card product-card p-4">

                <h2 class="text-primary mb-4">Изпрати съобщение</h2>

                <form>

                    <div class="mb-3">
                        <label class="form-label">Име</label>
                        <input type="text" class="form-control" placeholder="Вашето име">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="example@email.com">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Съобщение</label>
                        <textarea class="form-control" rows="5" placeholder="Вашето съобщение..."></textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-main btn-lg">
                            Изпрати съобщение
                        </button>
                    </div>

                </form>

            </div>

        </div>

    </div>

</div>