@model IEnumerable<FightGearShopApp.Models.Product.ProductIndexVM>
@{
    ViewData["Title"] = "Начало";
}

<style>
    body {
        background-color: #f8f9fa;
        color: #f8f9fa;
    }

    .hero {
        background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1549719386-74dfcbf7dbed');
        background-size: cover;
        background-position: center;
        padding: 120px 0;
    }

    .btn-main {
        background-color: #1d4ed8;
        border: none;
    }

        .btn-main:hover {
            background-color: #3b82f6;
        }

    .card {
        background-color: #0d1b2a;
        border: none;
        transition: 0.3s;
    }

        .card:hover {
            transform: scale(1.05);
        }

    .section-title {
        color: #2563eb;
        margin-bottom: 30px;
    }
</style>

<!-- HERO SECTION -->
<!-- HERO SLIDER -->
@{
    ViewData["Title"] = "Home Page";
}

<!-- HERO SLIDER -->
<div id="heroCarousel" class="carousel slide carousel-fade mb-5" data-bs-ride="carousel">

    <div class="carousel-inner">

        <!-- SLIDE 1 -->
        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?q=80&w=1600&auto=format&fit=crop"
                 class="d-block w-100" style="height: 90vh; object-fit: cover;" alt="Slide 1">
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100">
                <h1 class="display-3 fw-bold">БОЙНИ СПОРТОВЕ</h1>
                <p class="lead">Професионална екипировка за шампиони</p>
                <a class="btn btn-main btn-lg mt-3" asp-area="" asp-controller="Product" asp-action="Index">Разгледай</a>

            </div>
        </div>

        <!-- SLIDE 2 -->
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1579758629938-03607ccdbaba?q=80&w=1600&auto=format&fit=crop"
                 class="d-block w-100" style="height: 90vh; object-fit: cover;" alt="Slide 2">
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100">
                <h1 class="display-3 fw-bold">MMA ЕКИПИРОВКА</h1>
                <p class="lead">Създадена за издръжливост и сила</p>
                <a class="btn btn-main btn-lg mt-3" asp-area="" asp-controller="Product" asp-action="Index">Разгледай</a>
            </div>
        </div>

        <!-- SLIDE 3 -->
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=1600&auto=format&fit=crop"
                 class="d-block w-100" style="height: 90vh; object-fit: cover;" alt="Slide 3">
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100">
                <h1 class="display-3 fw-bold">ТРЕНИРАЙ КАТО ПРО</h1>
                <p class="lead">Всичко за фитнес и подготовка</p>
                <a class="btn btn-main btn-lg mt-3" asp-area="" asp-controller="Product" asp-action="Index">Разгледай</a>
            </div>
        </div>

    </div>

    <!-- CONTROLS -->
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>

    <!-- INDICATORS -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>

</div>

<!-- CONTROLS -->
<button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
</button>

<button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
</button>

<!-- INDICATORS -->
@* <div class="carousel-indicators">
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
</div> *@

</div>

<!-- CATEGORIES -->
<div class="container py-5">
    <h2 class="text-center section-title">Категории</h2>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card text-center p-3">
                <img src="https://images.unsplash.com/photo-1599058917765-a780eda07a3e" class="card-img-top" style="height:200px; object-fit:cover;">
                <div class="card-body">
                    <h5>
                        <a asp-controller="Product"
                           asp-action="Index"
                           asp-route-searchStringCategoryName="Boxing Gloves"
                           class="btn btn-warning">
                            Боксови ръкавици
                        </a>
                    </h5>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center p-3">
                <img src="https://images.unsplash.com/photo-1579758629938-03607ccdbaba" class="card-img-top" style="height:200px; object-fit:cover;">
                <div class="card-body">

                    <h5> <a asp-controller="Product"
                       asp-action="Index"
                       asp-route-searchStringCategoryName="Shin Pads"
                       class="btn btn-warning">
                       Протектори за крака
                    </a></h5>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center p-3">
                <img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438" class="card-img-top" style="height:200px; object-fit:cover;">
                <div class="card-body">
                    <h5> <a asp-controller="Product"
                       asp-action="Index"
                       asp-route-searchStringCategoryName="Boxing warps"
                       class="btn btn-warning">
                       Бинтове
                    </a></h5>
                    
                </div>
            </div>
        </div>

    </div>
</div>

<!-- FEATURED PRODUCTS -->
@if (Model != null && Model.Any() && this.User.Identity.IsAuthenticated)
{

    <div class="container py-5">
        <h2 class="text-center section-title">Продукти</h2>

        <div class="row g-4">


            @foreach (var item in Model)
            {
                <div class="col-md-3">
                    <div class="card p-2">
                        <img src="Html.DisplayFor(modelItem =>item.Picture)" alt="image" width="100" />
                        <div class="card-body text-center">
                            <h6>@Html.DisplayFor(modelItem=>item.ProductName)</h6>
                            <p>@Html.DisplayFor(modelItem=>item.Price)</p>
                           <a asp-action="Create" asp-controller="Order" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">Buy</a>
                        </div>
                    </div>
                </div>
            }           
        </div>
        <div class="text-center py-5">
            <h1>
                Готов ли си за тренировка?</h1>
            <a class="btn btn-main btn-lg mt-3" asp-area="" asp-controller="Product" asp-action="Index">Пазарувай сега</a>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <h1>Регистрирай се за да видиш още</h1>
        <a class="btn btn-main btn-lg mt-3" asp-area="Identity" asp-page="/Account/Login">Login now</a>
    </div>
}

   
    
  