                <div class="card-body">
                    <h5 class="card-title">Боксови ръкавици</h5>
                    <a href="#" class="btn btn-main">Виж</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center p-3">
                <img src="https://images.unsplash.com/photo-1579758629938-03607ccdbaba" class="card-img-top" style="height:200px; object-fit:cover;">
                <div class="card-body">
                    <h5 class="card-title">MMA екипировка</h5>
                    <a href="#" class="btn btn-main">Виж</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center p-3">
                <img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438" class="card-img-top" style="height:200px; object-fit:cover;">
                <div class="card-body">
                    <h5 class="card-title">Фитнес аксесоари</h5>
