@model IEnumerable<FightGearShopApp.Models.Product.ProductIndexVM>
@{
    ViewData["Title"] = "Продукти";
}

<h1 class="text-center text-primary mb-4">Продукти</h1>

@if ((this.User.Identity.IsAuthenticated) && (this.User.IsInRole("Administrator")))
{
    <p>
        <a asp-action="Create" class="btn btn-main mb-3">+ Добави продукт</a>
    </p>
}

<form asp-controller="Product" asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="SearchStringBrandName" class="form-control" placeholder="Марка">
        </div>
        <div class="col-md-4">
            <input type="text" name="SearchStringCategoryName" class="form-control" placeholder="Категория">
        </div>
        <div class="col-md-4">
            <input type="submit" value="Филтрирай" class="btn btn-main w-100">
        </div>
    </div>
</form>

<table class="table table-hover align-middle text-center">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ProductName)</th>
            <th>@Html.DisplayNameFor(model => model.BrandName)</th>
            <th>@Html.DisplayNameFor(model => model.CategoryName)</th>
            <th>Снимка</th>
            <th>@Html.DisplayNameFor(model => model.Quantity)</th>
            <th>@Html.DisplayNameFor(model => model.Price)</th>
            <th>@Html.DisplayNameFor(model => model.Discount)</th>
            <th>Действия</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.BrandName</td>
                <td>@item.CategoryName</td>
                <td>
                    <img src="@item.Picture" alt="Image" style="width:80px; height:80px; object-fit:cover; border-radius:6px;">
                </td>
                <td>@item.Quantity</td>
                <td>@item.Price лв.</td>
                <td>@item.Discount %</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-success btn-sm">Details</a>

                    @if (this.User.Identity.IsAuthenticated)
                    {
                        <a asp-action="Create" asp-controller="Order" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">Order</a>
                    }

                    @if ((this.User.Identity.IsAuthenticated) && (this.User.IsInRole("Administrator")))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}










