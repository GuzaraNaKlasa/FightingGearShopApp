@model FightGearShopApp.Models.Product.ProductCreateVM
@{
    ViewData["Title"] = "Добави продукт";
}

<div class="container py-5">

    <div class="card p-4 product-card mx-auto" style="max-width: 600px;">
        <h2 class="text-center text-primary mb-4">Добави нов продукт</h2>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="ProductName" class="form-label">Име на продукта</label>
                <input asp-for="ProductName" class="form-control" />
                <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BrandId" class="form-label">Марка</label>
                <select asp-for="BrandId" class="form-select text-center">
                    @foreach (var brand in Model.Brands)
                    {
                        <option value="@brand.Id">@brand.Name</option>
                    }
                </select>
                <span asp-validation-for="BrandId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Категория</label>
                <select asp-for="CategoryId" class="form-select text-center">
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Picture" class="form-label">URL на изображение</label>
                <input asp-for="Picture" class="form-control" />
                <span asp-validation-for="Picture" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Quantity" class="form-label">Количество</label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label">Цена</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Discount" class="form-label">Отстъпка (%)</label>
                <input asp-for="Discount" class="form-control" />
                <span asp-validation-for="Discount" class="text-danger"></span>
            </div>

            <div class="d-grid">
                <input type="submit" value="Добави продукт" class="btn btn-main btn-lg" />
            </div>
        </form>

        <div class="mt-3 text-center">
            <a asp-action="Index" class="btn btn-outline-secondary">Назад към списъка</a>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}